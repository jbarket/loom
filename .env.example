# Required: Path to your agent's identity/memory directory.
# This dir holds IDENTITY.md, preferences.md, self-model.md, pursuits.md,
# and the memories.db sqlite + sqlite-vec store.
LOOM_CONTEXT_DIR=~/.config/loom/default

# Optional: Override the memories.db location.
# Default: <LOOM_CONTEXT_DIR>/memories.db
# LOOM_SQLITE_DB_PATH=/path/to/custom/memories.db

# Optional: fastembed model for embeddings.
# Default: fast-bge-small-en-v1.5  (384-dim, ~33MB ONNX, CPU-only)
# Other supported: fast-bge-base-en-v1.5 (768-dim, ~110MB),
# fast-all-MiniLM-L6-v2 (384-dim), fast-multilingual-e5-large (1024-dim)
# LOOM_FASTEMBED_MODEL=fast-bge-small-en-v1.5

# Optional: where to cache downloaded ONNX models.
# Default: ~/.cache/loom/fastembed/
# LOOM_FASTEMBED_CACHE_DIR=/path/to/cache

# Default client adapter (optional, can be set per-call).
# Known values: claude-code, gemini-cli. Different runtimes use
# different MCP tool-name prefixes; the adapter tells loom which.
# LOOM_CLIENT=claude-code
